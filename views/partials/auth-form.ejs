<div class="mx-auto w-full max-w-md rounded-[28px] border border-white/10 bg-white/5 p-8 backdrop-blur-xl shadow-[0_25px_80px_rgba(10,14,39,0.45)]">
  <div class="mb-6">
    <p class="text-xs uppercase tracking-[0.2em] text-neon/80"><%= eyebrow %></p>
    <h1 class="mt-2 font-orbit text-3xl text-white"><%= title %></h1>
    <p class="mt-2 text-sm leading-6 text-slate-300"><%= description %></p>
  </div>

  <form method="post" action="<%= action %>" class="space-y-4">
    <% if (mode === 'register') { %>
      <div>
        <label class="mb-2 block text-sm text-slate-200">Name</label>
        <input type="text" name="name" required class="auth-input">
      </div>
    <% } %>

    <div>
      <label class="mb-2 block text-sm text-slate-200">Email</label>
      <input type="email" name="email" required class="auth-input">
    </div>

    <div>
      <label class="mb-2 block text-sm text-slate-200">Password</label>
      <input type="password" name="password" required class="auth-input">
    </div>

    <% if (mode === 'register') { %>
      <div>
        <label class="mb-2 block text-sm text-slate-200">Confirm Password</label>
        <input type="password" name="confirmPassword" required class="auth-input">
      </div>
    <% } %>

    <button type="submit" class="w-full rounded-2xl bg-gradient-to-r from-neon to-neon2 px-4 py-3 text-sm font-semibold text-white shadow-[0_10px_40px_rgba(0,212,255,0.25)]">
      <%= submitLabel %>
    </button>
  </form>

  <p class="mt-6 text-center text-sm text-slate-400">
    <%= footerText %> <a href="<%= footerLink %>" class="text-neon hover:underline"><%= footerLinkLabel %></a>
  </p>
</div>
