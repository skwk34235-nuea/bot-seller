<% if (flash && flash.message) { %>
  <div class="mx-auto mb-6 max-w-7xl px-4">
    <div class="rounded-2xl border px-4 py-3 text-sm <%= flash.type === 'error' ? 'border-red-400/30 bg-red-500/10 text-red-100' : 'border-neon/30 bg-neon/10 text-cyan-100' %>">
      <%= flash.message %>
    </div>
  </div>
<% } %>
