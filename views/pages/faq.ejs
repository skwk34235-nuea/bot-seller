<!doctype html>
<html lang="en" class="h-full">
  <%- include('../partials/head') %>
  <body class="min-h-full bg-deep text-white font-sara">
    <div class="page-shell">
      <%- include('../partials/navbar') %>
      <main class="mx-auto max-w-5xl px-4 py-16">
        <p class="text-sm uppercase tracking-[0.2em] text-neon/80" data-i18n="nav_faq">FAQ</p>
        <h1 class="mt-4 font-orbit text-4xl" data-i18n="faq_title">Common Questions</h1>
        <div class="mt-10 space-y-4">
          <% faqs.forEach((faq, index) => { %>
            <article class="glass-card rounded-[28px] p-6">
              <h2 class="font-orbit text-lg" data-i18n="f<%= index + 1 %>_q"><%= faq.question %></h2>
              <p class="mt-3 text-sm leading-7 text-slate-300" data-i18n="f<%= index + 1 %>_a"><%= faq.answer %></p>
            </article>
          <% }) %>
        </div>
      </main>
      <%- include('../partials/footer') %>
      <%- include('../partials/socket-badge') %>
      <%- include('../partials/scripts') %>
    </div>
  </body>
</html>
