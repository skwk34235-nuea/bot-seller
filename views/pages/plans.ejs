<!doctype html>
<html lang="en" class="h-full">
  <%- include('../partials/head') %>
  <body class="min-h-full bg-deep text-white font-sara">
    <div class="page-shell">
      <%- include('../partials/navbar') %>
      <main class="mx-auto max-w-7xl px-4 py-16">
        <p class="text-sm uppercase tracking-[0.2em] text-neon/80">Plans</p>
        <h1 class="mt-4 font-orbit text-4xl">Service Packages</h1>
        <div class="mt-10 grid gap-5 md:grid-cols-3">
          <% plans.forEach((plan) => { %>
            <article class="glass-card rounded-[28px] p-6">
              <p class="text-xs uppercase tracking-[0.18em]" style="color:<%= plan.accent %>" data-i18n="<%= plan.id === 'source' ? 'pl1_name' : plan.id === 'full-service' ? 'pl2_name' : 'pl4_name' %>"><%= plan.name %></p>
              <h2 class="mt-4 font-orbit text-2xl"><%= plan.price %></h2>
              <p class="mt-4 text-sm leading-6 text-slate-300" data-i18n="<%= plan.id === 'source' ? 'pl1_desc' : plan.id === 'full-service' ? 'pl2_desc' : 'pl4_desc' %>"><%= plan.description %></p>
            </article>
          <% }) %>
        </div>
      </main>
      <%- include('../partials/footer') %>
      <%- include('../partials/socket-badge') %>
      <%- include('../partials/scripts') %>
    </div>
  </body>
</html>
