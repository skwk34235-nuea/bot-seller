<!doctype html>
<html lang="en" class="h-full">
  <%- include('../partials/head') %>
  <body class="min-h-full bg-deep text-white font-sara">
    <div class="page-shell">
      <%- include('../partials/navbar') %>
      <%- include('../partials/flash') %>
      <main class="mx-auto max-w-7xl px-4 py-16">
        <div class="max-w-2xl">
          <p class="text-sm uppercase tracking-[0.2em] text-neon/80">Products</p>
          <h1 class="mt-4 font-orbit text-4xl">Bot Catalog</h1>
          <p class="mt-4 text-base leading-8 text-slate-300">Each product card can be wired to realtime order updates and customer status events through Socket.IO.</p>
        </div>
        <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
          <% products.forEach((product) => { %>
            <article class="glass-card rounded-[28px] p-6">
              <div class="flex items-center justify-between">
                <span class="rounded-full px-3 py-1 text-xs uppercase tracking-[0.16em] text-slate-200" style="background:<%= `${product.color}20` %>"><%= product.category %></span>
                <i data-lucide="<%= product.icon %>" class="h-5 w-5" style="color:<%= product.color %>"></i>
              </div>
              <h2 class="mt-5 font-orbit text-xl"><%= product.name %></h2>
              <p class="mt-3 text-sm leading-6 text-slate-300" data-i18n="p<%= product.id %>_desc"><%= product.description %></p>
              <ul class="mt-4 space-y-2 text-sm text-slate-200">
                <% product.features.forEach((feature, idx) => { %>
                  <li class="flex items-center gap-2" data-i18n="p<%= product.id %>_f<%= idx + 1 %>"><span class="h-1.5 w-1.5 rounded-full bg-neon"></span><%= feature %></li>
                <% }) %>
              </ul>
              <div class="mt-6 flex items-center justify-between">
                <span class="text-lg font-semibold text-neon"><%= product.price.toLocaleString() %> THB</span>
                <a href="/register" class="rounded-xl border border-neon/30 px-3 py-2 text-xs font-semibold text-neon hover:bg-neon/10">Order now</a>
              </div>
            </article>
          <% }) %>
        </div>
      </main>
      <%- include('../partials/footer') %>
      <%- include('../partials/socket-badge') %>
      <%- include('../partials/scripts') %>
    </div>
  </body>
</html>
