<!doctype html>
<html lang="en" class="h-full">
  <%- include('../partials/head') %>
  <body class="min-h-full bg-deep text-white font-sara">
    <div class="page-shell">
      <%- include('../partials/navbar') %>
      <main class="mx-auto max-w-7xl px-4 py-16">
        <p class="text-sm uppercase tracking-[0.2em] text-neon/80" data-i18n="nav_reviews">Reviews</p>
        <h1 class="mt-4 font-orbit text-4xl" data-i18n="review_title">Client Feedback</h1>
        <div class="mt-10 grid gap-5 md:grid-cols-3">
          <% reviews.forEach((review, index) => { %>
            <article class="glass-card rounded-[28px] p-6">
              <p class="text-sm text-neon"><%= review.bot %></p>
              <h2 class="mt-3 font-orbit text-xl"><%= review.name %></h2>
              <p class="mt-3 text-sm leading-7 text-slate-300" data-i18n="r<%= index + 1 %>_text"><%= review.text %></p>
              <p class="mt-4 text-sm text-amber-300"><%= '★'.repeat(review.rating) %></p>
            </article>
          <% }) %>
        </div>
      </main>
      <%- include('../partials/footer') %>
      <%- include('../partials/socket-badge') %>
      <%- include('../partials/scripts') %>
    </div>
  </body>
</html>
