<!doctype html>
<html lang="en" class="h-full">
  <%- include('../partials/head') %>
  <body class="min-h-full bg-deep text-white font-sara">
    <div class="page-shell">
      <%- include('../partials/navbar') %>
      <%- include('../partials/flash') %>

      <main>
        <section class="mx-auto grid max-w-7xl gap-8 px-4 py-16 md:grid-cols-[1.1fr_0.9fr] md:py-24">
          <div>
            <p class="text-sm uppercase tracking-[0.2em] text-neon/80" data-i18n="demo_title">Realtime bot commerce</p>
            <h1 class="mt-5 font-orbit text-4xl leading-tight text-white md:text-6xl"><%= appName %></h1>
            <p class="mt-6 max-w-2xl text-base leading-8 text-slate-300" data-i18n="hero_sub">Sell Discord bots with separate pages, account system, session auth, and Socket.IO ready for live notifications, ticket updates, and order status.</p>
            <div class="mt-8 flex flex-wrap gap-3">
              <a href="/products" data-i18n="btn_view_products" class="rounded-2xl bg-gradient-to-r from-neon to-neon2 px-5 py-3 text-sm font-semibold text-white">Browse products</a>
              <a href="/plans" data-i18n="btn_view_plans" class="rounded-2xl border border-neon/30 px-5 py-3 text-sm font-semibold text-neon">View Plans</a>
            </div>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <% products.forEach((product) => { %>
              <article class="glass-card rounded-[28px] p-5">
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl" style="background:<%= `${product.color}20` %>; color:<%= product.color %>;">
                  <i data-lucide="<%= product.icon %>" class="h-5 w-5"></i>
                </div>
                <h2 class="mt-2 font-orbit text-lg"><%= product.name %></h2>
                <p class="mt-3 text-sm leading-6 text-slate-300" data-i18n="p<%= product.id %>_desc"><%= product.description %></p>
                <p class="mt-4 text-sm font-semibold text-neon"><%= product.price.toLocaleString() %> THB</p>
              </article>
            <% }) %>
          </div>
        </section>

        <section class="mx-auto max-w-7xl px-4 pb-16">
          <div class="grid gap-4 md:grid-cols-3">
            <% plans.forEach((plan) => { %>
              <article class="glass-card rounded-[28px] p-6">
                <p class="text-xs uppercase tracking-[0.18em]" style="color:<%= plan.accent %>" data-i18n="<%= plan.id === 'source' ? 'pl1_name' : plan.id === 'full-service' ? 'pl2_name' : 'pl4_name' %>"><%= plan.name %></p>
                <p class="mt-3 font-orbit text-2xl text-white"><%= plan.price %></p>
                <p class="mt-3 text-sm leading-6 text-slate-300" data-i18n="<%= plan.id === 'source' ? 'pl1_desc' : plan.id === 'full-service' ? 'pl2_desc' : 'pl4_desc' %>"><%= plan.description %></p>
              </article>
            <% }) %>
          </div>
        </section>
      </main>

      <%- include('../partials/footer') %>
      <%- include('../partials/socket-badge') %>
      <%- include('../partials/scripts') %>
    </div>
  </body>
</html>
