<!doctype html>
<html lang="en" class="h-full">
  <%- include('../../partials/head') %>
  <body class="min-h-full bg-deep text-white font-sara">
    <div class="page-shell">
      <%- include('../../partials/navbar') %>
      <%- include('../../partials/flash') %>
      <main class="mx-auto max-w-7xl px-4 py-16">
        <div class="mb-10">
          <p class="text-sm uppercase tracking-[0.2em] text-amber-300">Admin area</p>
          <h1 class="mt-4 font-orbit text-4xl">Admin Dashboard</h1>
          <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-300">This area is reserved for admin sessions and keeps management screens separate from the normal user side.</p>
        </div>

        <div class="grid gap-4 md:grid-cols-3">
          <% stats.forEach((stat) => { %>
            <section class="glass-card rounded-[28px] p-6">
              <p class="text-xs uppercase tracking-[0.16em] text-slate-400"><%= stat.label %></p>
              <p class="mt-4 font-orbit text-4xl text-neon"><%= stat.value %></p>
            </section>
          <% }) %>
        </div>

        <div class="mt-8 grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
          <section class="glass-card rounded-[28px] p-6">
            <div class="flex items-center justify-between">
              <h2 class="font-orbit text-2xl">Recent users</h2>
              <a href="/admin/users" class="rounded-xl border border-neon/30 px-3 py-2 text-xs font-semibold text-neon hover:bg-neon/10">View all</a>
            </div>
            <div class="mt-6 space-y-3">
              <% recentUsers.forEach((user) => { %>
                <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                  <p class="text-sm font-semibold text-white"><%= user.name %></p>
                  <p class="mt-1 text-sm text-slate-400"><%= user.email %></p>
                  <p class="mt-2 text-xs uppercase tracking-[0.16em] text-amber-300"><%= user.role %></p>
                </div>
              <% }) %>
            </div>
          </section>

          <section class="glass-card rounded-[28px] p-6">
            <p class="text-sm uppercase tracking-[0.18em] text-neon/80">Realtime control</p>
            <h2 class="mt-3 font-orbit text-2xl">Broadcast admin message</h2>
            <form id="adminRealtimeForm" class="mt-5 space-y-4">
              <textarea id="adminRealtimeMessage" class="auth-input min-h-[140px]" placeholder="Send a message to the admin realtime channel"></textarea>
              <button type="submit" class="w-full rounded-2xl bg-gradient-to-r from-neon to-neon2 px-4 py-3 text-sm font-semibold text-white">Broadcast message</button>
            </form>
            <div id="adminRealtimeLog" class="mt-5 rounded-2xl border border-white/10 bg-black/10 p-4 text-sm text-slate-300">Waiting for admin events...</div>
          </section>
        </div>
      </main>
      <%- include('../../partials/footer') %>
      <%- include('../../partials/socket-badge') %>
      <%- include('../../partials/scripts') %>
      <script>
        const adminRealtimeForm = document.getElementById('adminRealtimeForm');
        const adminRealtimeMessage = document.getElementById('adminRealtimeMessage');
        const adminRealtimeLog = document.getElementById('adminRealtimeLog');

        adminRealtimeForm.addEventListener('submit', function (event) {
          event.preventDefault();
          if (!window.appSocket || !adminRealtimeMessage.value.trim()) {
            return;
          }
          window.appSocket.emit('notify:admin', { text: adminRealtimeMessage.value.trim() });
          adminRealtimeMessage.value = '';
        });

        document.addEventListener('socket:admin-message', function (event) {
          const payload = event.detail;
          adminRealtimeLog.textContent = `[${payload.sentAt}] ${payload.source}: ${payload.text}`;
        });
      </script>
    </div>
  </body>
</html>
