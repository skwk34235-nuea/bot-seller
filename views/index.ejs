  <style>
*{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%;overflow:hidden}
#app{height:100%;overflow-y:auto;overflow-x:hidden}
.stars{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0}
.star{position:absolute;background:#fff;border-radius:50%;animation:twinkle var(--d) infinite alternate}
@keyframes twinkle{0%{opacity:.2;transform:scale(.8)}100%{opacity:1;transform:scale(1.2)}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
@keyframes glow-pulse{0%,100%{box-shadow:0 0 15px rgba(0,212,255,.3),0 0 30px rgba(0,212,255,.1)}50%{box-shadow:0 0 25px rgba(0,212,255,.5),0 0 50px rgba(0,212,255,.2)}}
@keyframes slideUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
@keyframes slideDown{from{opacity:0;transform:translateY(-30px)}to{opacity:1;transform:translateY(0)}}
@keyframes slideLeft{from{opacity:0;transform:translateX(30px)}to{opacity:1;transform:translateX(0)}}
@keyframes slideRight{from{opacity:0;transform:translateX(-30px)}to{opacity:1;transform:translateX(0)}}
@keyframes zoomIn{from{opacity:0;transform:scale(0.85)}to{opacity:1;transform:scale(1)}}
@keyframes flipIn{from{opacity:0;transform:perspective(500px) rotateX(-90deg)}to{opacity:1;transform:perspective(500px) rotateX(0deg)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.glow-btn{background:linear-gradient(135deg,#00d4ff,#7b5cff);animation:glow-pulse 3s infinite;transition:all .3s}
.glow-btn:hover{transform:scale(1.05);box-shadow:0 0 40px rgba(0,212,255,.6)}
.glass-card{background:rgba(17,22,64,0.55);backdrop-filter:blur(16px);border:1px solid rgba(0,212,255,.15);transition:all .4s}
.glass-card:hover{border-color:rgba(0,212,255,.4);transform:translateY(-4px);box-shadow:0 8px 32px rgba(0,212,255,.15)}
.nav-link{position:relative;transition:color .3s}
.nav-link::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:2px;background:linear-gradient(90deg,#00d4ff,#7b5cff);transition:width .3s}
.nav-link:hover::after,.nav-link.active::after{width:100%}
.anim-up{animation:slideUp .6s cubic-bezier(0.16,1,0.3,1) both}
.anim-down{animation:slideDown .6s cubic-bezier(0.16,1,0.3,1) both}
.anim-left{animation:slideLeft .6s cubic-bezier(0.16,1,0.3,1) both}
.anim-right{animation:slideRight .6s cubic-bezier(0.16,1,0.3,1) both}
.anim-zoom{animation:zoomIn .6s cubic-bezier(0.16,1,0.3,1) both}
.anim-flip{animation:flipIn .6s cubic-bezier(0.16,1,0.3,1) both}
.anim-fade{animation:fadeIn .6s cubic-bezier(0.16,1,0.3,1) both}
.tag{background:rgba(0,212,255,.12);border:1px solid rgba(0,212,255,.25);color:#00d4ff;font-size:.7rem;padding:2px 8px;border-radius:9999px}
.star-rating i{cursor:pointer;transition:all .2s}
.ticket-status{display:inline-block;padding:2px 10px;border-radius:9999px;font-size:.7rem;font-weight:600}
.status-pending{background:rgba(255,193,7,.15);color:#ffc107;border:1px solid rgba(255,193,7,.3)}
.status-checked{background:rgba(0,212,255,.15);color:#00d4ff;border:1px solid rgba(0,212,255,.3)}
.status-done{background:rgba(76,175,80,.15);color:#4caf50;border:1px solid rgba(76,175,80,.3)}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);backdrop-filter:blur(4px);z-index:100;display:flex;align-items:center;justify-content:center;animation:fadeIn .2s}
.toast{position:fixed;top:20px;right:20px;z-index:200;padding:12px 20px;border-radius:12px;animation:slideUp .3s ease-out;font-family:'Sarabun',sans-serif}
input,textarea,select{background:rgba(10,14,39,.8)!important;border:1px solid rgba(0,212,255,.2)!important;color:#e0e6ff!important;border-radius:8px!important;padding:8px 12px!important;font-family:'Sarabun',sans-serif!important;width:100%}
input:focus,textarea:focus,select:focus{outline:none!important;border-color:#00d4ff!important;box-shadow:0 0 12px rgba(0,212,255,.2)!important}
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:#0a0e27}
::-webkit-scrollbar-thumb{background:linear-gradient(#00d4ff,#7b5cff);border-radius:3px}
.nebula{position:fixed;border-radius:50%;filter:blur(80px);pointer-events:none;z-index:0;opacity:.15}
</style>
