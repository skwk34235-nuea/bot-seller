    <p class="text-xs">Source Code ที่ซื้อสามารถใช้งานได้เฉพาะตัว ห้ามนำไปจำหน่ายต่อ ห้ามแจกจ่ายโดยไม่ได้รับอนุญาต</p>
    <h3 class="font-orbit text-sm text-neon">4. การชำระเงิน</h3>
    <p class="text-xs">ชำระเงินผ่าน QR Code / PromptPay เท่านั้น ต้องอัปโหลดสลิปเพื่อยืนยัน แอดมินจะตรวจสอบภายใน 1-3 ชั่วโมง</p>
    <h3 class="font-orbit text-sm text-neon">5. การยกเลิก</h3>
    <p class="text-xs">สามารถยกเลิกได้ก่อนเริ่มพัฒนา หลังเริ่มพัฒนาแล้วไม่สามารถยกเลิกได้ กรณีบอทสั่งทำจะคืนเงิน 50% หากยกเลิกระหว่างพัฒนา</p>
  </div>
</section>`
};

// Functions
function filterProducts(catId){
  const buttons = document.querySelectorAll('.category-btn');
  buttons.forEach(btn => {
    if(btn.dataset.cat === catId) {
       btn.className = "category-btn px-4 py-1.5 rounded-full text-xs font-bold transition glow-btn text-white";
    } else {
       btn.className = "category-btn px-4 py-1.5 rounded-full text-xs font-bold transition border border-white/10 text-gray-400 hover:border-neon/40 hover:text-neon";
    }
  });

  const grid = document.getElementById('productsGrid');
  const filtered = catId === 'all' ? products : products.filter(p => p.cat === catId);
  const animStyles={'music':'anim-left','security':'anim-flip','workflow':'anim-zoom','custom':'anim-down','all':'anim-up'};
  const animClass = animStyles[catId] || 'anim-up';
  
  grid.innerHTML = filtered.map((p,i)=>`
    <div class="glass-card rounded-2xl p-5 flex flex-col ${animClass}" style="animation-delay:${i*0.06}s">
      <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-3" style="background:${p.color}15;border:1px solid ${p.color}30">
        <i data-lucide="${p.icon}" style="width:22px;height:22px;color:${p.color}"></i>
      </div>
      <h3 class="font-orbit text-sm font-bold mb-1" style="color:${p.color}">${p.name}</h3>
      <p class="text-xs text-gray-400 mb-3 flex-1">${p.desc}</p>
      <div class="flex flex-wrap gap-1 mb-3">${p.features.map(f=>`<span class="tag">${f}</span>`).join('')}</div>
      <div class="flex items-center justify-between mt-auto">
        <span class="font-orbit text-sm font-bold text-white">฿${p.price.toLocaleString()}</span>
        <button onclick="startOrder(${p.id})" class="glow-btn px-4 py-1.5 rounded-lg text-xs font-bold text-white">${t('prod_buy')}</button>
      </div>
    </div>`).join('');
    
  lucide.createIcons();
}

function startOrder(id){navigate('order',id)}

function submitOrder(e,productId){
  e.preventDefault();
  const order={
    id:Date.now(),productId,
    name:document.getElementById('ordName').value,
    discord:document.getElementById('ordDiscord').value,
    email:document.getElementById('ordEmail').value,
    plan:document.getElementById('orderPlan').value,
    note:document.getElementById('ordNote').value,
    status:'pending',date:new Date().toLocaleDateString(currentLang==='th'?'th-TH':'en-US')
  };
  orders.push(order);
  showToast(t('msg_order_success'));
  navigate('home');
}

function submitContact(e){
  e.preventDefault();
  showToast(t('msg_submit_req'));
  e.target.reset();
}

let reviewRating=5;
function setReviewRating(r){
  reviewRating=r;
  document.querySelectorAll('#reviewStars span').forEach((s,i)=>{s.style.color=i<r?'#facc15':'#4b5563'});
}

function submitReview(e){
  e.preventDefault();
  reviews.push({name:document.getElementById('revName').value,avatar:'⭐',rating:reviewRating,text:document.getElementById('revText').value,bot:document.getElementById('revBot').value});
  showToast(t('msg_submit_rev'));
  navigate('reviews');
}

function createTicket(e){
  e.preventDefault();
  tickets.push({id:1000+tickets.length,name:document.getElementById('tkName').value,topic:document.getElementById('tkTopic').value,detail:document.getElementById('tkDetail').value,status:'pending',reply:null});
  showToast(t('msg_submit_tk'));
  navigate('support');
}

function replyTicket(idx){
  const el=document.createElement('div');
  el.className='modal-overlay';
  el.onclick=e=>{if(e.target===el)el.remove()};
  el.innerHTML=`<div class="glass-card rounded-2xl p-6 w-full max-w-md mx-4"><h3 class="font-orbit text-sm mb-3 text-neon">${t('tk_reply_admin')} #${tickets[idx].id}</h3><textarea id="replyText" rows="3" placeholder="พิมพ์ข้อความตอบกลับ..."></textarea><div class="flex gap-2 mt-3"><button onclick="saveReply(${idx})" class="glow-btn px-4 py-1.5 rounded-lg text-xs font-bold text-white">ส่ง</button><button onclick="this.closest('.modal-overlay').remove()" class="px-4 py-1.5 rounded-lg text-xs border border-white/20 text-gray-400">ยกเลิก</button></div></div>`;
  document.body.appendChild(el);
}

function saveReply(idx){
  tickets[idx].reply=document.getElementById('replyText').value;
  tickets[idx].status='checked';
  document.querySelector('.modal-overlay').remove();
  showToast(t('msg_reply_saved'));
  navigate('admin');
}

function closeTicket(idx){tickets[idx].status='done';showToast(t('msg_tk_closed'));navigate('admin')}
function updateOrderStatus(idx,status){orders[idx].status=status;showToast(t('msg_ord_updated'));navigate('admin')}

function toggleFaq(i){
  const a=document.getElementById('faqAnswer'+i);
  const ic=document.getElementById('faqIcon'+i);
  a.classList.toggle('hidden');
  ic.style.transform=a.classList.contains('hidden')?'':'rotate(180deg)';
}

// Stars
function createStars(){
  const c=document.getElementById('stars');
  for(let i=0;i<80;i++){
    const s=document.createElement('div');
    s.className='star';
    s.style.cssText=`left:${Math.random()*100}%;top:${Math.random()*100}%;width:${1+Math.random()*2}px;height:${1+Math.random()*2}px;--d:${2+Math.random()*3}s;animation-delay:${Math.random()*3}s`;
    c.appendChild(s);
  }
}

// Element SDK
const defaultConfig={store_name:'Starlight Bot Store',hero_subtitle:'Premium Discord Bots — บอทคุณภาพสูง พร้อมใช้งาน ดูแลตลอด',background_color:'#0a0e27',surface_color:'#111640',text_color:'#e0e6ff',primary_action_color:'#00d4ff',secondary_action_color:'#7b5cff',font_family:'Sarabun',font_size:14};

function applyConfig(cfg){
  const c={...defaultConfig,...cfg};
  document.body.style.background=c.background_color;
  document.body.style.color=c.text_color;
  document.body.style.fontFamily=`${c.font_family}, Sarabun, sans-serif`;
  
  const ht=document.getElementById('heroTitle');
  if(ht)ht.textContent=c.store_name;
  const hs=document.getElementById('heroSub');
  if(hs)hs.textContent=c.hero_subtitle;
  const nt=document.getElementById('navTitle');
  if(nt)nt.textContent=c.store_name;

  document.querySelectorAll('.font-orbit').forEach(el=>{el.style.fontFamily=`Orbitron, ${c.font_family}, sans-serif`});
  document.querySelectorAll('.glass-card').forEach(el=>{el.style.background=c.surface_color+'99';el.style.borderColor=c.primary_action_color+'25'});
  document.querySelectorAll('.glow-btn').forEach(el=>{el.style.background=`linear-gradient(135deg,${c.primary_action_color},${c.secondary_action_color})`});

  const base=c.font_size||14;
  document.querySelectorAll('p,span,a,li,label').forEach(el=>{if(!el.closest('.font-orbit'))el.style.fontSize=`${base}px`});
}

if(window.elementSdk){
  window.elementSdk.init({
    defaultConfig,
    onConfigChange:async(cfg)=>applyConfig(cfg),
    mapToCapabilities:(cfg)=>({
      recolorables:[
        {get:()=>cfg.background_color||defaultConfig.background_color,set:v=>{cfg.background_color=v;window.elementSdk.setConfig({background_color:v})}},
        {get:()=>cfg.surface_color||defaultConfig.surface_color,set:v=>{cfg.surface_color=v;window.elementSdk.setConfig({surface_color:v})}},
        {get:()=>cfg.text_color||defaultConfig.text_color,set:v=>{cfg.text_color=v;window.elementSdk.setConfig({text_color:v})}},
        {get:()=>cfg.primary_action_color||defaultConfig.primary_action_color,set:v=>{cfg.primary_action_color=v;window.elementSdk.setConfig({primary_action_color:v})}},
        {get:()=>cfg.secondary_action_color||defaultConfig.secondary_action_color,set:v=>{cfg.secondary_action_color=v;window.elementSdk.setConfig({secondary_action_color:v})}}
      ],
      borderables:[],
      fontEditable:{get:()=>cfg.font_family||defaultConfig.font_family,set:v=>{cfg.font_family=v;window.elementSdk.setConfig({font_family:v})}},
      fontSizeable:{get:()=>cfg.font_size||defaultConfig.font_size,set:v=>{cfg.font_size=v;window.elementSdk.setConfig({font_size:v})}}
    }),
    mapToEditPanelValues:(cfg)=>new Map([
      ['store_name',cfg.store_name||defaultConfig.store_name],
      ['hero_subtitle',cfg.hero_subtitle||defaultConfig.hero_subtitle]
    ])
  });
}

createStars();
navigate('home');
lucide.createIcons();
</script>
