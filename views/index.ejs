    <div class="glass-card rounded-xl p-5 stagger-item anim-up">
      <h3 class="font-orbit text-sm mb-3 text-neon2">🎫 Tickets ล่าสุด</h3>
      ${tickets.length?tickets.slice(-5).reverse().map((t,i)=>`
      <div class="py-2 border-b border-white/5 last:border-0">
        <div class="flex items-center justify-between mb-1">
          <span class="text-sm font-bold">#${t.id} ${t.topic}</span>
