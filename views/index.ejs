// Toast
function showToast(msg,type='success'){
  const c=document.getElementById('toastContainer');
  const t=document.createElement('div');
  t.className=`toast glass-card text-sm ${type==='error'?'border-red-500/50 text-red-300':'border-neon/50 text-neon'}`;
  t.textContent=msg;
  c.appendChild(t);
  setTimeout(()=>t.remove(),3000);
}

// Navigation
function navigate(page,data){
  currentPage=page;
  document.querySelectorAll('.nav-link').forEach(l=>{l.classList.remove('active');if(l.dataset.nav===page)l.classList.add('active')});
  const container=document.getElementById('pageContainer');
  container.innerHTML=pages[page]?pages[page](data):'';
  container.querySelectorAll('.stagger-item').forEach((el,i)=>{el.style.animationDelay=`${i*0.06}s`});
  document.getElementById('app').scrollTo({top:0,behavior:'smooth'});
  lucide.createIcons();
}

function toggleMobileMenu(){document.getElementById('mobileMenu').classList.toggle('hidden')}

